# Auto detect text files and perform LF normalization
* text=auto

# Binary files - never modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.aac binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary
*.zip binary
*.gz binary
*.apk binary
*.aab binary
